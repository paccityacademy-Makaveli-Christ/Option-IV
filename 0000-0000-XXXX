            } else if (total < 4.5) {
                insight = `Good job! Your footprint is slightly above or near the sustainable global average (4.0 t CO₂e). Focus on your biggest contributor.`;
            } else if (total < 8.0) {
                insight = `Above average. Your footprint is higher than the global average (4.0 t CO₂e). Significant reduction opportunities exist in ${breakdown[0].name}.`;
            } else {
                insight = `High emissions. Your footprint is significantly higher than the global average (4.0 t CO₂e). Consider major changes in ${breakdown[0].name} for the biggest impact.`;
            }
            DOM.insightText.textContent = insight;

            // Re-render Lucide icons for dynamically added HTML
            renderLucideIcons();
        }

        /**
         * Renders the interactive button groups.
         * @param {HTMLElement} container - The DOM element to render buttons into.
         * @param {Array<Object>} options - Array of {value, label, icon}.
         * @param {string} stateKey - Key in the global state object to update.
         */
        function renderButtons(container, options, stateKey) {
            container.innerHTML = options.map(option => `
                <button
                    data-value="${option.value}"
                    data-key="${stateKey}"
                    class="flex flex-col items-center justify-center p-3 rounded-xl border-2 transition-all duration-200
                        ${state.diet === option.value || state.recycling === option.value ?
                            'border-primary bg-primary/20 dark:bg-primary-dark/30 text-primary dark:text-primary font-bold shadow-lg' :
                            'border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-700 hover:border-primary/50 hover:bg-gray-100 dark:hover:bg-gray-600'
                        }
                    "
                >
                    <i data-lucide="${option.icon}" class="w-5 h-5 mb-1"></i>
                    <span class="text-xs">${option.label}</span>
                </button>
            `).join('');

            // Re-attach event listeners to the new buttons
            container.querySelectorAll('button').forEach(button => {
                button.addEventListener('click', (e) => {
                    const value = e.currentTarget.getAttribute('data-value');
                    const key = e.currentTarget.getAttribute('data-key');
                    state[key] = value;
                    // Re-render both button groups to update selection styles
                    renderButtons(DOM.dietOptions, DIET_OPTIONS, 'diet');
                    renderButtons(DOM.recyclingOptions, RECYCLING_OPTIONS, 'recycling');
                    renderResults();
                });
            });

            // Re-render Lucide icons for the buttons
            renderLucideIcons();
        }

        /**
         * Renders all Lucide icons found on the page.
         */
        function renderLucideIcons() {
            if (window.lucide) {
                window.lucide.createIcons();
            }
        }

        // 5. INITIALIZATION AND EVENT HANDLERS

        /**
         * Attaches all primary event listeners to inputs.
         */
        function setupEventListeners() {
            // Helper function to handle slider input updates
            const handleSliderInput = (slider, display, unit, stateKey) => {
                slider.addEventListener('input', (e) => {
                    const value = parseInt(e.target.value);
                    state[stateKey] = value;
                    display.textContent = `${value} ${unit}`;
                    renderResults();
                });
            };

            // Setup for all range sliders
            handleSliderInput(DOM.electricity, DOM.electricityValue, 'kWh', 'electricity');
            handleSliderInput(DOM.driving, DOM.drivingValue, 'km', 'driving');
            handleSliderInput(DOM.flights, DOM.flightsValue, 'flight' + (state.flights !== 1 ? 's' : ''), 'flights');

            // The flights slider needs a special unit handler to change 'flight' vs 'flights'
            DOM.flights.addEventListener('input', (e) => {
                const value = parseInt(e.target.value);
                const unit = value === 1 ? 'flight' : 'flights';
                DOM.flightsValue.textContent = `${value} ${unit}`;
            });

            // Dark Mode Toggle
            DOM.themeToggle.addEventListener('click', toggleTheme);

            // Initial render of buttons
