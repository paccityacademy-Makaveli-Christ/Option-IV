        const sunMesh = new THREE.Mesh(sunGeo, sunMat);
        // Sun Glow
        const sunGlow = new THREE.Sprite(new THREE.SpriteMaterial({ 
            map: glowTexture, 
            color: 0xffaa00, 
            transparent: true, 
            opacity: 0.8,
            blending: THREE.AdditiveBlending 
        }));
        sunGlow.scale.set(3, 3, 3);
        sunMesh.add(sunGlow);
        // Sun diameter 1.4 million km = 1.4e9 meters. Log10 is ~9.15
        addToScene(sunMesh, 9.15, "The Sun", "1.4 million km diameter (10^9 m)");

        // --- SCALE 13: SOLAR SYSTEM (Represented by orbit lines) ---
        const solarSysGroup = new THREE.Group();
        const orbitMat = new THREE.LineBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.3 });
        [0.4, 0.7, 1.0, 1.5, 5.2, 9.5].forEach(radiusAU => {
            // 1 AU ~ 150 million km = 1.5e11 m. 
            // Relative to sun (10^9), 1AU is 100x bigger.
            // In visual units where Sun is size 1 (at 10^9 scale), 1AU is radius 100.
            const orbitPoints = [];
            const r = radiusAU * 100; // scaled visual representation
            for(let i=0; i<=64; i++) {
                const angle = (i/64) * Math.PI * 2;
                orbitPoints.push(new THREE.Vector3(Math.cos(angle)*r, 0, Math.sin(angle)*r));
            }
            const lineGeo = new THREE.BufferGeometry().setFromPoints(orbitPoints);
            const line = new THREE.Line(lineGeo, orbitMat);
            line.rotation.x = Math.PI/2;
            solarSysGroup.add(line);
        });
        // We place this roughly at the scale of the outer planets
        addToScene(solarSysGroup, 12, "Solar System", "~100 AU (10^13 m)");


        // --- SCALE 21: GALAXY ---
        const galaxyGroup = new THREE.Group();
        const pGeo = new THREE.BufferGeometry();
        const pCount = 5000;
        const pPositions = [];
        const pColors = [];
        const colorInside = new THREE.Color(0xffaa00);
        const colorOutside = new THREE.Color(0x0055ff);

        for(let i=0; i<pCount; i++) {
            // Spiral math
            const angle = Math.random() * Math.PI * 2;
            const radius = Math.random(); // 0 to 1
            const spiralAngle = angle + (radius * 10); // twist
            const x = Math.cos(spiralAngle) * radius * 5; // spread out
            const z = Math.sin(spiralAngle) * radius * 5;
            const y = (Math.random() - 0.5) * (1 - radius) * 0.5; // thinner at edges
            
            pPositions.push(x, y, z);

            // Color mix
            const mixedColor = colorInside.clone().lerp(colorOutside, radius);
            pColors.push(mixedColor.r, mixedColor.g, mixedColor.b);
        }

        pGeo.setAttribute('position', new THREE.Float32BufferAttribute(pPositions, 3));
        pGeo.setAttribute('color', new THREE.Float32BufferAttribute(pColors, 3));
        const pMat = new THREE.PointsMaterial({ size: 0.05, vertexColors: true, blending: THREE.AdditiveBlending, transparent: true });
        const galaxyPoints = new THREE.Points(pGeo, pMat);
        galaxyGroup.add(galaxyPoints);
        // Milky way diameter ~100k light years = 10^21 meters
        addToScene(galaxyGroup, 20.8, "Milky Way Galaxy", "100,000 Light Years (10^21 m)");


        // --- 4. LIGHTING ---
        const ambientLight = new THREE.AmbientLight(0x404040); // Soft white light
        scene.add(ambientLight);
        
        // Point light attached to camera (like a headlight) so we can see things
        const camLight = new THREE.PointLight(0xffffff, 1, 0);
        camera.add(camLight);
        scene.add(camera);
        
        // Sun light (only active when near sun scale)
        const sunLight = new THREE.PointLight(0xffaa00, 2, 0);
        scene.add(sunLight);


        // --- 5. LOGIC & ANIMATION ---

        let currentZoom = 0; // The exponent
        const slider = document.getElementById('zoomSlider');
        const scaleLabel = document.getElementById('scale-label');
        const scaleDesc = document.getElementById('scale-desc');

        // Mouse Wheel Handler
        document.addEventListener('wheel', (e) => {
            let newVal = parseFloat(slider.value) + (e.deltaY * 0.005);
            newVal = Math.max(-16, Math.min(22, newVal));
            slider.value = newVal;
        });

        function updateLabels(zoom) {
            const power = Math.floor(zoom);
            scaleLabel.innerText = `10^${power} meters`;
            
            // Find closest object description
            let closestDist = Infinity;
            let activeDesc = "";
            let activeName = "";

            objects.forEach(obj => {
                const dist = Math.abs(obj.userData.baseScale - zoom);
                if (dist < 1.5 && dist < closestDist) {
                    closestDist = dist;
                    activeName = obj.userData.name;
                    activeDesc = obj.userData.desc;
                }
            });

            if(activeName) {
                scaleDesc.innerHTML = `<span style="color:#4cc9f0">${activeName}</span><br>${activeDesc}`;
            } else {
                scaleDesc.innerText = "Traveling light...";
            }
        }

        function animate() {
            requestAnimationFrame(animate);

            // Smooth zoom interpolation
            const targetZoom = parseFloat(slider.value);
            currentZoom += (targetZoom - currentZoom) * 0.1;

            updateLabels(currentZoom);

            // Update Objects
            objects.forEach(obj => {
                const scaleDiff = currentZoom - obj.userData.baseScale;
                
                // Calculate scale factor relative to camera
                // If zoom matches object scale, object should be Size 1 (or its native size)
                // If we zoom OUT (increase Zoom number), object gets smaller.
                
                // 3D Scale formula: Scale = 1 / 10^(currentZoom - objectBaseScale)
                // However, Javascript floats fail with massive numbers. 
                // So we only render if within a "Visible Window".
                
                // Visible window: -5 to +5 relative orders of magnitude
                if (scaleDiff > -5 && scaleDiff < 10) {
                    obj.visible = true;
                    
                    // The scale logic:
                    // If I am at 10^0 (1m) and look at Earth (10^7), Earth is huge.
                    // If I am at 10^9 (Sun) and look at Earth (10^7), Earth is small.
                    
                    // Let's use a base visual size. 
                    const visualScale = Math.pow(10, obj.userData.baseScale - currentZoom);
                    
                    obj.scale.setScalar(visualScale);
                    
                    // Simple rotation for effect
                    obj.rotation.y += 0.002;
                    if(obj.userData.name === "Atom") {
                         electronSystem.rotation.x += 0.01;
                         electronSystem.rotation.y += 0.01;
                    }
                } else {
                    obj.visible = false;
                }
            });
            
            // Background Starfield logic (simple particles that move towards camera)
            // We can't actually move them, but we can rotate the background to feel dynamic
            scene.rotation.z += 0.0005;

            renderer.render(scene, camera);
        }

        // Handle window resize
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        animate();

    </script>
</body>
</html>

