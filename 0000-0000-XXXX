// 1. ATOMIC ENTITY (R1)
class AtomicEntity extends Entity {
    constructor() {
        super("Atomic Structure (R1)", "Electromagnetic Force", "Electron cloud orbital and voltage potential.");
        this.electrons = [];
        this.nucleus = null;
        this.cloud = null;
        this.ionized = false; // State flag for ionization event
        this.excited = false; // State flag for orbital excitation
        this.shockHalo = null; // Visual effect for shockwave
        this.shockStart = 0;
        this.baseColor = new THREE.Color(CONFIG.ACCENT_COLOR);
    }

    rebuild(elementData) {
        this.group.clear();
        this.electrons = [];
        this.ionized = false; // Reset ionization state
        this.excited = false;
        
        const data = elementData;
        const size = 0.2 * data.eSpeed;
        const cloudRadius = 3 * data.eSpeed;
        this.baseColor.set(data.color);

        // Nucleus
        this.nucleus = new THREE.Mesh(new THREE.SphereGeometry(size, 16, 16), new THREE.MeshBasicMaterial({ color: data.color, emissive: data.color, emissiveIntensity: 0.1 }));
        this.group.add(this.nucleus);

        // Shock Halo (for Cherenkov-like visual effect on impact)
        this.shockHalo = new THREE.Mesh(
            new THREE.SphereGeometry(size * 1.5, 32, 32),
            new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0, wireframe: true, blending: THREE.AdditiveBlending })
        );
        this.group.add(this.shockHalo);


        // Electron Cloud (Points)
        const pGeo = new THREE.BufferGeometry();
        const pos = [];
        for (let i = 0; i < 500; i++) {
            const r = cloudRadius * (0.8 + Math.random() * 0.2);
            const theta = Math.random() * Math.PI * 2;
            const phi = Math.acos(2 * Math.random() - 1);
            pos.push(r * Math.sin(phi) * Math.cos(theta), r * Math.sin(phi) * Math.sin(theta), r * Math.cos(phi));
        }
        pGeo.setAttribute('position', new THREE.Float32BufferAttribute(pos, 3));
        const cloudColor = new THREE.Color(data.group.includes('Conductor') ? 0x00ffff : 0xaaaaaa);
        const pMat = new THREE.PointsMaterial({
            color: cloudColor, size: 0.15, map: particleTex, transparent: true, opacity: 0.5, blending: THREE.AdditiveBlending
        });
        this.cloud = new THREE.Points(pGeo, pMat);
        this.group.add(this.cloud);

        // Explicit Valence Electrons
        for (let i = 0; i < data.valence; i++) {
            const e = new THREE.Mesh(new THREE.SphereGeometry(0.1), new THREE.MeshBasicMaterial({ color: CONFIG.ACCENT_COLOR, emissive: CONFIG.ACCENT_COLOR, emissiveIntensity: 0.8 }));
            e.userData.baseRadius = cloudRadius * (0.5 + 0.5 * (i / data.valence));
            e.userData.radius = e.userData.baseRadius; // Current radius
            e.userData.orbitSpeed = i * 0.5 + 1;
            e.userData.flyOut = false; // Trigger for ionization arc
            e.userData.decayRate = 0; 
            e.userData.flyStart = 0;
            this.electrons.push(e);
            this.group.add(e);
        }
    }

    // --- INTERACTION LOGIC (FULL ARC TRIGGERING) ----
    // This method sets the state flags (ionized, excited, flyOut) based on the photon collision.
    applyPhotonInteraction(photon, t, state, elementData) {
        if (!photon || !photon.waveMesh) return;
        const nucleusPos = this.group.position;
        // Distance calculated from the moving wave mesh
        const dist = photon.waveMesh.position.distanceTo(nucleusPos);
        
        const energy = state.photonEnergyInput;
        const amp = state.ampMultiplier;

        // Dynamic Bandgap Calculation
        const logR = Math.log10(elementData.resistivity + 1e-18); 
        // Maps logR (-18 for superconductor to 5 for insulator) to a bandgap range (0.1 eV to 5.0 eV)
        const bandgapFactor = THREE.MathUtils.mapLinear(logR, -18, 5, 0.1, 5.0); 
        const coupling = energy * amp;
        const effectiveThreshold = bandgapFactor * 0.9;
        
        // --- Shock Halo Trigger ---
        if (dist < 0.5) {
            if (!this.excited) {
                this.excited = true; // Use excited temporarily for shock trigger
                this.shockStart = t;
            }
        }
        
        // --- Shock Halo Visual Expansion ---
        if (this.excited) {
            const dt = (t - this.shockStart) * 2.0;
            this.shockHalo.material.opacity = Math.max(0, 1.0 - dt);
            this.shockHalo.scale.setScalar(1 + dt * 3);
            if(this.shockHalo.material.opacity === 0) {
                this.excited = false; // Reset excited flag if shock is gone
            }
        } else {
             this.shockHalo.material.opacity = 0; // Ensure reset if no hit
        }
        
        // --- Collision check and Excitation/Ionization State Setting ---
        for (let e of this.electrons) {
            
            // Check if the wave is close to the electron's orbit
            if (dist < e.userData.baseRadius * 0.8) {

                // EXCITATION/IONIZATION CONDITION
                if (coupling > effectiveThreshold && !e.userData.flyOut) {

                    // Trigger fly-out physics
                    e.userData.flyOut = true;
                    e.userData.flyStart = t;
                    
                    // Energy-weighted decay rate for return curve (faster decay for less energy)
                    e.userData.decayRate = THREE.MathUtils.clamp(coupling / (bandgapFactor * 3), 0.1, 1.5);
                    
                    // Excited color flash
                    e.material.emissiveIntensity = 2.5;
                    e.material.color.set(0xffffff);
                }
            }
        }
    }

    // This method handles the continuous movement and decay based on the state set in applyPhotonInteraction
    update(t, state, elementData, photon) {
        // Step 1: Run the triggering logic
        this.applyPhotonInteraction(photon, t, state, elementData); 
        
        const data = elementData;
        const groundedT = t * state.photonTimeFactor * state.timeDilation;
        
        const conductivityFactor = data.eSpeed / 2.5;
        const orbitSpeedMultiplier = conductivityFactor * state.photonEnergyInput * state.freqMultiplier;

        // --- Electron State Machine Logic (Movement and Decay) ---
        for (let e of this.electrons) {
            const electronMat = e.material;
            
            // State: FLY-OUT BEHAVIOR (Excitation or Ionization)
            if (e.userData.flyOut) {
                const dt = (t - e.userData.flyStart) * state.timeDilation;
                
                // Direction = radial from nucleus (set at trigger time)
                const dir = e.position.clone().normalize();
                
                // Position is radial acceleration
                const scale = (1 + dt * 4 * e.userData.decayRate); 
                e.position.copy(dir).multiplyScalar(e.userData.baseRadius * scale);

                // Ionization threshold – electron escapes cloud radius
                if (!this.ionized && e.position.length() > 6 * elementData.eSpeed) {
                    this.ionized = true;
                    e.material.color.set(0xff0000); // Ionized Red
                }

                // Return curve (if not ionized)
                if (!this.ionized) {
                    // Check if decay time is reached
                    if (dt > 1.0 / e.userData.decayRate) {
                        e.userData.flyOut = false; // Return to normal orbit
                        e.material.color.set(CONFIG.ACCENT_COLOR);
                        e.material.emissiveIntensity = 0.8;
                        // Set new excited radius (larger than base but will decay back)
                        e.userData.radius = e.userData.baseRadius * (1 + 0.2 * state.photonEnergyInput); 
                    }
                } else {
                    // If ionized, the electron continues to fly out and fade
                    if (e.position.length() > 15) {
                         // Reset position far away to simulate escape
                         e.position.set(0,0,0); 
                         e.userData.flyOut = false;
                         // A real app would rebuild/re-init the electron here, but for this demo, we let it disappear.
                    }
                }
                
            } else {
                // State: NORMAL/DECAYING ORBIT
                
                // Decay radius back to base radius slowly
                if (e.userData.radius > e.userData.baseRadius) {
                     e.userData.radius -= 0.1 * (e.userData.radius - e.userData.baseRadius) * (t - e.userData.lastT || 0);
                     e.userData.radius = Math.max(e.userData.radius, e.userData.baseRadius);
                }
                
                // Decay color and intensity
                electronMat.color.lerp(this.baseColor, 0.05);
                electronMat.emissiveIntensity = THREE.MathUtils.lerp(electronMat.emissiveIntensity, 0.8, 0.05);

                // Normal Orbit Movement
                const angle = (groundedT * e.userData.orbitSpeed * orbitSpeedMultiplier) + e.userData.radius;
                
                // Set the position on the newly decayed radius
                e.position.x = Math.cos(angle) * e.userData.radius;
                e.position.z = Math.sin(angle) * e.userData.radius;
                e.position.y = Math.cos(angle * 0.5) * 0.2; // Slight vertical wobble
            }
            e.userData.lastT = t;
        }

        // --- GLOBAL ATOMIC STATE COLOR SHIFT ---
        if (this.ionized) {
            // Nuclear burnout glow
            this.nucleus.material.color.set(0xff0000);
            this.nucleus.material.emissive.set(0xff2200);
            this.nucleus.material.emissiveIntensity = 0.8;
            
            // Cloud thinning
            this.cloud.material.opacity = Math.max(0.1, 0.5 - 0.25 * Math.sin(t * 2));
        } else {
            // Cloud ripple reset
            this.cloud.material.opacity = THREE.MathUtils.lerp(this.cloud.material.opacity, 0.5, 0.1);
            
            // Nucleus glow reset
            this.nucleus.material.emissiveIntensity = THREE.MathUtils.lerp(this.nucleus.material.emissiveIntensity, 0.1, 0.05);
            this.nucleus.material.color.set(this.baseColor);
            this.nucleus.material.emissive.set(this.baseColor);
        }

        // Cloud rotation and size
        this.cloud.rotation.y = groundedT * 0.5;
        this.cloud.material.size = 0.15 * state.photonEnergyInput;
        const cloudScale = 1 + 0.05 * Math.sin(t * 3 * state.freqMultiplier) * state.ampMultiplier; 
        this.cloud.scale.set(cloudScale, cloudScale, cloudScale); 
    }
}

// 2. PHOTON WAVEFRONT ENTITY (R2)
class PhotonWavefront extends Entity {
    constructor() {
        super("Photon Wavefront (R2)", "Electromagnetic Wave", "Incoming wave exciting the atomic structure.");
        this.waveMesh = null;
        this.geometry = new THREE.PlaneGeometry(15, 15, 60, 60);
        this.material = new THREE.MeshBasicMaterial({
            color: CONFIG.ACCENT_COLOR,
            wireframe: true,
            transparent: true,
            opacity: 0.4,
            side: THREE.DoubleSide
        });
    }

    rebuild() {
        // Dispose of old geometry to prevent memory leak
        if (this.waveMesh) {
            this.waveMesh.geometry.dispose();
        }
        this.group.clear();
        this.geometry = new THREE.PlaneGeometry(15, 15, 60, 60);
        this.waveMesh = new THREE.Mesh(this.geometry, this.material);
        this.waveMesh.position.z = -10; // Start wave far back (will flow forward towards +Z)
        this.waveMesh.rotation.x = Math.PI / 2; // Face the atom correctly
        this.group.add(this.waveMesh);
    }

    update(t, state, elementData) {
        const { freqMultiplier, ampMultiplier, photonEnergyInput } = state;
        const positionAttribute = this.geometry.attributes.position;
        const numVertices = positionAttribute.count;

        // Wave propagation speed depends on energy input (relativity)
        const waveSpeed = 2 + photonEnergyInput * 0.5;
        const waveTime = t * waveSpeed;

        for (let i = 0; i < numVertices; i++) {
            // Original x-position (in the geometry space)
            const x = positionAttribute.getX(i); 
            // Original y-position (in the geometry space)
            const y = positionAttribute.getY(i); 
            
            // Calculate displacement for wave effect
            const displacement = Math.sin(
                // X component (wave front) - creating ripple effect across the plane
                x * 2 * freqMultiplier + waveTime * freqMultiplier * 5 
            ) * Math.cos(
                 // Y component (wave amplitude) - for vertical motion 
                y * 1.5
            ) * ampMultiplier * 0.4; // Max displacement amplitude

            positionAttribute.setZ(i, displacement); // Displacement along Z axis
        }

        positionAttribute.needsUpdate = true;
        
        // Make the entire wave "flow" through the atom (along Z-axis from -10 to +10)
        this.waveMesh.position.z = (waveTime * 0.8) % 20 - 10;
        
        // Update opacity based on energy input
        this.waveMesh.material.opacity = 0.2 + THREE.MathUtils.clamp(photonEnergyInput * 0.1, 0, 0.6);
        this.waveMesh.material.color.set(CONFIG.ACCENT_COLOR).multiplyScalar(1 + photonEnergyInput * 0.2);
    }
}


