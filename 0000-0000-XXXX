    <script>
        // --- Core Application Logic ---

        // 1. CONSTANTS & CONFIG
        // Factors in kg CO₂e per unit (approximate global averages)
        const FACTORS = {
            // Annualize monthly/weekly inputs
            electricity: 300 * 12, // kg CO₂e per kWh (Global avg) * 12 months
            driving: 0.17 * 52, // kg CO₂e per km (avg gasoline car) * 52 weeks
            flights: 1500, // kg CO₂e per long-haul flight (approx 7,000km)
            diet: {
