                'high-meat': 3300,
                'low-meat': 2100,
                'vegetarian': 1600,
                'vegan': 1200,
            },
            recycling: {
                // Annual kg CO₂e reduction based on effort
                'none': 0,
                'some': -100,
                'all': -250, // Dedicated recycling reduces footprint
            },
            // Constant emissions floor (clothing, infrastructure, etc.)
            other: 2000,
        };

        const DIET_OPTIONS = [
            { value: 'high-meat', label: 'High Meat', icon: 'Drumstick' },
            { value: 'low-meat', label: 'Low Meat', icon: 'Milk' },
            { value: 'vegetarian', label: 'Vegetarian', icon: 'Carrot' },
            { value: 'vegan', label: 'Vegan', icon: 'Apple' },
        ];

        const RECYCLING_OPTIONS = [
            { value: 'none', label: 'None', icon: 'X' },
            { value: 'some', label: 'Some', icon: 'Check' },
            { value: 'all', label: 'Dedicated', icon: 'Recycle' }, // Lucide is case-insensitive, this works!
        ];

        // 2. STATE MANAGEMENT (Simple object for reactive data)
        const state = {
            electricity: 300, // kWh/month
            driving: 100, // km/week
            flights: 1, // flights/year
            diet: 'low-meat',
            recycling: 'some',
        };

        // 3. CACHED DOM ELEMENTS
        const DOM = {
            electricity: document.getElementById('electricity'),
            electricityValue: document.getElementById('electricity-value'),
            driving: document.getElementById('driving'),
            drivingValue: document.getElementById('driving-value'),
            flights: document.getElementById('flights'),
            flightsValue: document.getElementById('flights-value'),
            dietOptions: document.getElementById('diet-options'),
            recyclingOptions: document.getElementById('recycling-options'),
            totalFootprint: document.getElementById('total-footprint'),
            insightText: document.getElementById('insight-text'),
            breakdownList: document.getElementById('breakdown-list'),
            themeToggle: document.getElementById('theme-toggle'),
        };

        // 4. CALCULATION & RENDERING FUNCTIONS

        /**
         * Calculates the total annual CO2e footprint in kg.
         * @returns {{total: number, breakdown: Array<{name: string, value: number}>}}
         */
        function calculateFootprint() {
            // Convert monthly/weekly inputs to annual kg CO2e
            const electricityKg = (state.electricity * 12) * FACTORS.electricity / 300; // Scaled to input range
            const drivingKg = (state.driving * 52) * FACTORS.driving / 0.17 / 52; // Scaled to input range
            const flightsKg = state.flights * FACTORS.flights;
            const dietKg = FACTORS.diet[state.diet];
            const recyclingKg = FACTORS.recycling[state.recycling];
            const otherKg = FACTORS.other;

            const totalKg = electricityKg + drivingKg + flightsKg + dietKg + recyclingKg + otherKg;
            const totalTonnes = totalKg / 1000;

            const breakdown = [
                { name: 'Electricity', value: electricityKg, icon: 'Zap' },
                { name: 'Driving', value: drivingKg, icon: 'Car' },
                { name: 'Flights', value: flightsKg, icon: 'Plane' },
                { name: 'Diet', value: dietKg, icon: 'Vegan' },
                { name: 'Other (General)', value: otherKg, icon: 'Boxes' },
                { name: 'Recycling (Reduction)', value: recyclingKg, icon: 'Recycle' },
            ].filter(item => item.value !== 0); // Remove zero entries

            // Sort descending by absolute value for the breakdown list
            breakdown.sort((a, b) => Math.abs(b.value) - Math.abs(a.value));

            return { total: totalTonnes, breakdown };
        }

        /**
         * Updates the result display with calculated data.
         */
        function renderResults() {
            const { total, breakdown } = calculateFootprint();

            // 1. Total Footprint Display (Tonnes)
            DOM.totalFootprint.textContent = total.toFixed(1);

            // 2. Breakdown List (Top 3)
            DOM.breakdownList.innerHTML = breakdown.slice(0, 3).map(item => {
                const isReduction = item.value < 0;
                const sign = isReduction ? '↓' : '↑';
                const color = isReduction ? 'text-green-500' : 'text-red-500';

                return `
                    <li class="flex justify-between items-center bg-gray-100 dark:bg-gray-700 p-2 rounded-lg">
